<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>ATLANTIS · NEW YORK</title>
<meta name="description" content="Descend into a drowned New York. An interactive abyss.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Space+Mono&display=swap" rel="stylesheet">
<style>
:root{--ink:#e9f5f6;--teal:#7fece0;--gold:#f4dca6}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;overflow:hidden;background:#02060e}
body{font-family:"Cormorant Garamond",Georgia,serif;color:var(--ink);cursor:grab;-webkit-tap-highlight-color:transparent}
body.grab{cursor:grabbing}

/* ---- stage (the 4 real images) ---- */
#stage{position:fixed;inset:0;z-index:1;overflow:hidden}
.layer{position:absolute;inset:-4%;background-size:cover;background-position:center;
  will-change:transform,opacity;opacity:0}
#stage.dive{filter:url(#water)}

/* ---- overlays ---- */
#fx{position:fixed;inset:0;z-index:2;pointer-events:none}
#grade{position:fixed;inset:0;z-index:3;pointer-events:none;
  background:radial-gradient(120% 100% at 50% 42%,transparent 38%,rgba(2,8,18,.72) 100%)}
#tint{position:fixed;inset:0;z-index:3;pointer-events:none;background:#02060e;opacity:0}

/* ---- UI ---- */
#ui{position:fixed;inset:0;z-index:6;pointer-events:none}
#hud{position:absolute;top:24px;left:26px;opacity:0;transition:opacity 1.4s ease}
#hud.on{opacity:1}
#hud .loc{font-family:"Cinzel",serif;font-size:15px;letter-spacing:.18em;text-shadow:0 1px 18px #000}
#hud .m{font-family:"Space Mono",monospace;font-size:11px;letter-spacing:.22em;color:var(--teal);margin-top:6px}
#hint{position:absolute;left:50%;bottom:30px;transform:translateX(-50%);opacity:0;transition:opacity 1.4s ease;
  font-family:"Space Mono",monospace;font-size:10px;letter-spacing:.38em;text-transform:uppercase;color:rgba(127,236,224,.6)}
#hint.on{opacity:1;animation:hp 3.4s ease-in-out infinite}
@keyframes hp{0%,100%{opacity:.3;transform:translateX(-50%) translateY(0)}50%{opacity:.85;transform:translateX(-50%) translateY(7px)}}

#cap{position:absolute;left:50%;bottom:13%;transform:translate(-50%,18px);text-align:center;max-width:min(680px,88vw);
  opacity:0;transition:opacity 1.1s ease,transform 1.1s ease}
#cap.show{opacity:1;transform:translate(-50%,0)}
#cap .e{font-family:"Space Mono",monospace;font-size:10px;letter-spacing:.42em;text-transform:uppercase;color:var(--gold);opacity:.9}
#cap .l{font-style:italic;font-size:clamp(20px,3.1vw,32px);line-height:1.3;margin-top:12px;
  text-shadow:0 2px 38px rgba(0,0,0,.9),0 0 30px rgba(127,236,224,.25)}

/* sponsor billboards */
.bill{position:absolute;pointer-events:none;text-align:center;padding:13px 20px;border:1px solid;border-radius:3px;
  background:rgba(3,12,20,.34);backdrop-filter:blur(2px);opacity:0;transform:translate(-50%,-50%) scale(.9);
  transition:opacity .8s ease;will-change:opacity}
.bill .nm{font-family:"Cinzel",serif;font-weight:700;font-size:16px;letter-spacing:.05em;line-height:1.05}
.bill .tg{font-style:italic;font-size:13px;color:rgba(233,245,246,.72);margin-top:4px}
.bill img{max-width:140px;max-height:60px;object-fit:contain;display:block}

/* finale banner */
#banner{position:absolute;left:50%;top:42%;transform:translate(-50%,-50%);text-align:center;opacity:0;transition:opacity 1.4s ease}
#banner .ny{font-family:"Cinzel",serif;font-size:14px;letter-spacing:.62em;color:#f59a3c;opacity:.9}
#banner .y73{font-family:"Space Mono",monospace;font-size:13px;letter-spacing:.42em;color:rgba(233,245,246,.82);margin-top:8px}
#banner .y26{font-family:"Cinzel",serif;font-weight:700;font-size:clamp(46px,9vw,104px);line-height:1;margin:4px 0;
  background:linear-gradient(180deg,#ffb259,#2f86d6);-webkit-background-clip:text;background-clip:text;color:transparent;
  filter:drop-shadow(0 0 30px rgba(245,154,60,.55))}
#banner .no{font-family:"Space Mono",monospace;font-size:13px;letter-spacing:.34em;color:#2f86d6}

/* overlays: intro / end / loader */
.ov{position:fixed;inset:0;z-index:20;display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:7vw;transition:opacity 1.4s ease;background:radial-gradient(130% 120% at 50% 30%,rgba(6,24,36,.55),rgba(2,6,14,.93))}
.ov.hide{opacity:0;pointer-events:none}
.kick{font-family:"Space Mono",monospace;font-size:11px;letter-spacing:.5em;text-transform:uppercase;color:var(--teal);opacity:.85}
h1{font-family:"Cinzel",serif;font-weight:700;font-size:clamp(50px,13vw,150px);line-height:.86;letter-spacing:.06em;margin:20px 0 0;
  text-shadow:0 0 80px rgba(127,236,224,.3),0 6px 50px rgba(0,0,0,.7)}
h1 .s{display:block;font-family:"Cormorant Garamond",serif;font-style:italic;font-weight:300;font-size:.23em;
  letter-spacing:.3em;color:var(--gold);margin-top:22px;text-shadow:none}
.tag{max-width:560px;font-size:clamp(17px,2.4vw,21px);font-weight:300;line-height:1.55;color:rgba(233,245,246,.86);margin:34px auto 0}
.btn{margin-top:44px;pointer-events:auto;cursor:pointer;background:none;font-family:"Space Mono",monospace;font-size:12px;
  letter-spacing:.34em;text-transform:uppercase;color:var(--ink);border:1px solid rgba(127,236,224,.45);
  padding:18px 44px;border-radius:2px;transition:.45s ease;backdrop-filter:blur(3px)}
.btn:hover,.btn:focus-visible{background:rgba(127,236,224,.1);border-color:var(--teal);letter-spacing:.44em;
  box-shadow:0 0 48px rgba(127,236,224,.22);outline:none}
.note{margin-top:30px;font-style:italic;font-size:14px;color:var(--gold);opacity:.8}
.foot{position:absolute;bottom:22px;font-family:"Space Mono",monospace;font-size:10px;letter-spacing:.32em;color:rgba(233,245,246,.32)}
#end .epi{font-style:italic;font-weight:300;font-size:clamp(22px,3.6vw,34px);line-height:1.4;max-width:680px;text-shadow:0 0 46px rgba(127,236,224,.32)}
#load{position:fixed;inset:0;z-index:30;display:flex;align-items:center;justify-content:center;background:#02060e;transition:opacity 1s ease}
#load.hide{opacity:0;pointer-events:none}
#load .l{font-family:"Space Mono",monospace;font-size:11px;letter-spacing:.4em;text-transform:uppercase;color:rgba(127,236,224,.6);animation:hp 2s ease-in-out infinite}
@media (prefers-reduced-motion:reduce){#hint.on,#load .l{animation:none}}
</style>
</head>
<body>

<div id="stage">
  <div class="layer" id="L0" style="background-image:url('01-surface.png')"></div>
  <div class="layer" id="L1" style="background-image:url('02-descent.png')"></div>
  <div class="layer" id="L2" style="background-image:url('03-times-square.png')"></div>
  <div class="layer" id="L3" style="background-image:url('04-garden.png')"></div>
</div>

<canvas id="fx"></canvas>
<div id="tint"></div>
<div id="grade"></div>

<div id="ui">
  <div id="hud"><div class="loc" id="loc">SURFACE</div><div class="m">−<span id="dV">0</span> M</div></div>
  <div id="hint">scroll · drag · ↓ &nbsp;to descend</div>
  <div id="cap"><div class="e" id="capE"></div><div class="l" id="capL"></div></div>
  <div id="banner">
    <div class="ny">NEW YORK</div><div class="y73">— 1973 —</div>
    <div class="y26">2026</div><div class="no">· 11 ·</div>
  </div>
</div>

<div class="ov" id="start">
  <div class="kick">40°42′N&nbsp;&nbsp;74°00′W &nbsp;·&nbsp; depth unrecorded</div>
  <h1>ATLANTIS<span class="s">the drowned city of New York</span></h1>
  <p class="tag">The tide came in and never left. Far below, a few lights still refuse the dark. Hold your breath — and go down.</p>
  <button class="btn" id="go">Begin the descent</button>
  <div class="note">The lights down there are for sale — sponsor a drowned landmark.</div>
  <div class="foot">atlantisnyc.com</div>
</div>

<div class="ov hide" id="end">
  <div class="kick">the seabed · −3,600 m</div>
  <p class="epi" id="endT" style="margin-top:26px"></p>
  <button class="btn" id="again" style="margin-top:36px">Rise, and dive again</button>
  <div class="note">Want your light glowing in the abyss? — atlantisnyc.com</div>
</div>

<div id="load"><div class="l">flooding the city…</div></div>

<!-- water distortion filter -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <filter id="water" x="-6%" y="-6%" width="112%" height="112%">
      <feTurbulence type="fractalNoise" baseFrequency="0.006 0.011" numOctaves="2" seed="7" result="n">
        <animate attributeName="baseFrequency" dur="20s" repeatCount="indefinite"
          values="0.006 0.011;0.0085 0.014;0.006 0.011"/>
      </feTurbulence>
      <feDisplacementMap id="disp" in="SourceGraphic" in2="n" scale="0" xChannelSelector="R" yChannelSelector="G"/>
    </filter>
  </defs>
</svg>

<!-- ============================================================
     SPONSORS — edit to sell ad slots. stage: 0 surface · 1 canyon ·
     2 times square · 3 garden.  x/y in % of screen. logo optional.
     ============================================================ -->
<script>
const SPONSORS=[
  {name:"YOUR BRAND", tag:"sponsor this sign", color:"#7fece0", stage:2, x:24, y:30},
  {name:"AVAILABLE",  tag:"adopt a ruin",      color:"#ff7da0", stage:2, x:78, y:24},
  {name:"YOUR LOGO",  tag:"the last light",    color:"#f4a64c", stage:3, x:50, y:74},
  // {name:"Acme", tag:"proud sponsor of the abyss", color:"#ffd166", stage:3, x:50, y:70, logo:"logo.png"},
];
</script>

<script>
const RM=matchMedia('(prefers-reduced-motion:reduce)').matches;
const stage=document.getElementById('stage');
const L=[0,1,2,3].map(i=>document.getElementById('L'+i));
const disp=document.getElementById('disp');
const fx=document.getElementById('fx'), fctx=fx.getContext('2d');
const tint=document.getElementById('tint');

/* stage anchors along depth 0..1 */
const ANCHOR=[0.0,0.34,0.67,1.0];
const LOCS=[["SURFACE",0],["THE CANYON",1200],["TIMES SQUARE · SUBMERGED",2400],["MADISON SQUARE GARDEN",3600]];
const CAPS=[
  [0.04,"Manhattan · the day the tide stayed","The last evening the city stood above the water."],
  [0.30,"Descent · the canyon","Down past the towers, the daylight gives up."],
  [0.60,"Times Square · 80 fathoms","Even drowned, the city refuses to turn off its signs."],
  [0.90,"The Garden","Fifty-three years to raise the banner. An ocean couldn't take it down."],
];

/* ---- depth control ---- */
let depth=0, target=0, started=false, ended=false;
const clamp=v=>Math.max(0,Math.min(1,v));
addEventListener('wheel',e=>{target=clamp(target+e.deltaY*0.0006);},{passive:true});
let drag=false,ly=0;
const down=y=>{drag=true;ly=y;document.body.classList.add('grab');};
const move=y=>{if(drag){target=clamp(target+(ly-y)*0.0012);ly=y;}};
const up=()=>{drag=false;document.body.classList.remove('grab');};
stage.addEventListener('mousedown',e=>down(e.clientY));
addEventListener('mousemove',e=>{move(e.clientY);pointer(e.clientX,e.clientY);});
addEventListener('mouseup',up);
stage.addEventListener('touchstart',e=>down(e.touches[0].clientY),{passive:true});
stage.addEventListener('touchmove',e=>move(e.touches[0].clientY),{passive:true});
stage.addEventListener('touchend',up);
addEventListener('keydown',e=>{const k=e.key.toLowerCase();
  if(k==='arrowdown'||k==='s')target=clamp(target+0.022);
  if(k==='arrowup'||k==='w')target=clamp(target-0.022);
  if(['arrowdown','arrowup',' '].includes(k))e.preventDefault();});
let px=0.5,py=0.5,tpx=0.5,tpy=0.5;
function pointer(x,y){tpx=x/innerWidth;tpy=y/innerHeight;}

/* ---- sponsors DOM ---- */
const ui=document.getElementById('ui');
const bills=SPONSORS.map(s=>{const el=document.createElement('div');el.className='bill';
  el.style.left=s.x+'%';el.style.top=s.y+'%';el.style.borderColor=s.color;el.style.color=s.color;
  el.style.boxShadow=`0 0 50px ${hexA(s.color,.4)}, inset 0 0 26px ${hexA(s.color,.12)}`;
  el.innerHTML=s.logo?`<img src="${s.logo}" alt="${s.name}">`:`<div class="nm">${s.name}</div><div class="tg">${s.tag}</div>`;
  ui.appendChild(el);return {s,el};});
function hexA(h,a){h=h.replace('#','');return`rgba(${parseInt(h.substr(0,2),16)},${parseInt(h.substr(2,2),16)},${parseInt(h.substr(4,2),16)},${a})`;}

/* ---- particles ---- */
let snow=[],bub=[],W,H,DPR;
function resize(){DPR=Math.min(devicePixelRatio||1,2);W=innerWidth;H=innerHeight;
  fx.width=W*DPR;fx.height=H*DPR;fx.style.width=W+'px';fx.style.height=H+'px';fctx.setTransform(DPR,0,0,DPR,0,0);
  snow=[];const n=RM?60:170;for(let i=0;i<n;i++)snow.push({x:Math.random()*W,y:Math.random()*H,z:.3+Math.random(),s:.4+Math.random()*1.8});}
addEventListener('resize',resize);

/* ---- captions ---- */
let capIdx=0,capTimer=0;
function caps(dt){
  if(capIdx<CAPS.length && depth>=CAPS[capIdx][0]){
    document.getElementById('capE').textContent=CAPS[capIdx][1];
    document.getElementById('capL').textContent=CAPS[capIdx][2];
    document.getElementById('cap').classList.add('show');capTimer=5.5;capIdx++;}
  if(capTimer>0){capTimer-=dt;if(capTimer<=0)document.getElementById('cap').classList.remove('show');}
}

/* ---- main loop ---- */
let t0=0,T=0;
function frame(ts){requestAnimationFrame(frame);
  if(!t0)t0=ts;const dt=Math.min(.05,(ts-t0)/1000);t0=ts;T+=dt;
  depth+=(target-depth)*Math.min(1,dt*3.0);
  px+=(tpx-px)*Math.min(1,dt*2.5);py+=(tpy-py)*Math.min(1,dt*2.5);

  // layer cross-dissolve + ken burns + parallax
  const parX=(px-0.5), parY=(py-0.5);
  for(let i=0;i<4;i++){
    const d=Math.abs(depth-ANCHOR[i]);
    const seg=0.34;
    let op=1-Math.min(1,d/seg); op=op*op*(3-2*op);      // smoothstep
    const zoom=1.04 + (depth-ANCHOR[i])*0.6 + Math.sin(T*0.1+i)*0.004;
    const tx=parX*-22*(1+i*0.2), ty=parY*-16 + (depth-ANCHOR[i])*40;
    L[i].style.opacity=op.toFixed(3);
    L[i].style.transform=`scale(${Math.max(1,zoom).toFixed(4)}) translate(${tx.toFixed(1)}px,${ty.toFixed(1)}px)`;
    L[i].style.zIndex=Math.round(op*100);
  }

  // underwater intensity ramps after surface
  const sub=Math.min(1,Math.max(0,(depth-0.07)/0.16));
  disp.setAttribute('scale',(sub*(RM?6:15)).toFixed(2));
  if(sub>0.01)stage.classList.add('dive'); else stage.classList.remove('dive');
  tint.style.opacity=(Math.max(0,(depth-0.5))*0.5).toFixed(3); // deepen the deep

  drawFX(dt,sub);

  // hud
  if(started){const seg=Math.min(3,Math.floor(depth/0.34+0.001));
    const m=Math.round(depth*3600);
    document.getElementById('loc').textContent=LOCS[Math.min(3,Math.round(depth*3))][0];
    document.getElementById('dV').textContent=m;}

  // finale banner near garden
  const b=document.getElementById('banner');
  const bp=1-Math.min(1,Math.abs(depth-0.93)/0.1);
  b.style.opacity=(bp*bp).toFixed(3);

  // sponsors visibility by stage proximity
  bills.forEach(({s,el})=>{const prox=1-Math.min(1,Math.abs(depth-ANCHOR[s.stage])/0.16);
    el.style.opacity=(Math.max(0,prox)*0.96).toFixed(3);
    el.style.transform=`translate(-50%,-50%) scale(${(0.9+prox*0.18).toFixed(3)})`;});

  caps(dt);
  if(started&&!ended&&depth>0.99){ended=true;finish();}
}

function drawFX(dt,sub){
  fctx.clearRect(0,0,W,H);
  // caustic shimmer near surface (additive light bands)
  const surf=Math.max(0,1-depth/0.4);
  if(surf>0.01&&!RM){fctx.globalCompositeOperation='lighter';
    for(let i=0;i<5;i++){const x=(i+0.5)/5*W+Math.sin(T*0.3+i)*40;
      const g=fctx.createLinearGradient(x,0,x-110,H);
      g.addColorStop(0,`rgba(180,236,220,${0.05*surf})`);g.addColorStop(1,'rgba(180,236,220,0)');
      fctx.fillStyle=g;fctx.beginPath();fctx.moveTo(x-30,0);fctx.lineTo(x+30,0);fctx.lineTo(x-60,H);fctx.lineTo(x-120,H);fctx.closePath();fctx.fill();}}
  // marine snow
  fctx.globalCompositeOperation='lighter';
  snow.forEach(p=>{p.y-=(6+p.z*12)*dt;p.x+=Math.sin((p.y+T*30)*0.01)*0.3;
    if(p.y<-4){p.y=H+4;p.x=Math.random()*W;}
    fctx.globalAlpha=(0.05+p.z*0.13)*(0.4+0.6*sub);
    fctx.fillStyle='#cdeef2';fctx.beginPath();fctx.arc(p.x,p.y,p.s,0,7);fctx.fill();});
  fctx.globalAlpha=1;
  // bubbles
  if(!RM&&sub>0.2&&Math.random()<0.3)bub.push({x:Math.random()*W,y:H+10,r:1+Math.random()*3,l:1});
  bub.forEach(b=>{b.y-=40*dt;b.l-=dt*0.25;b.x+=Math.sin(b.y*0.05)*0.4;
    fctx.globalAlpha=Math.max(0,b.l)*0.4;fctx.strokeStyle='#bfeef2';fctx.lineWidth=1;
    fctx.beginPath();fctx.arc(b.x,b.y,b.r,0,7);fctx.stroke();});
  bub=bub.filter(b=>b.l>0&&b.y>-10);
  fctx.globalAlpha=1;fctx.globalCompositeOperation='source-over';
}

/* ---- flow ---- */
function begin(){document.getElementById('start').classList.add('hide');
  document.getElementById('end').classList.add('hide');
  document.getElementById('hud').classList.add('on');
  document.getElementById('hint').classList.add('on');
  started=true;ended=false;capIdx=0;depth=target=0;}
function finish(){document.getElementById('endT').textContent=
  "You reached the floor of a city that drowned with the lights on. Whatever you came for, the water is keeping it warm.";
  document.getElementById('hud').classList.remove('on');document.getElementById('hint').classList.remove('on');
  setTimeout(()=>document.getElementById('end').classList.remove('hide'),1000);}
document.getElementById('go').addEventListener('click',begin);
document.getElementById('again').addEventListener('click',begin);

/* ---- preload then run ---- */
const srcs=['01-surface.png','02-descent.png','03-times-square.png','04-garden.png'];
let loaded=0;
srcs.forEach(s=>{const im=new Image();im.onload=im.onerror=()=>{if(++loaded===srcs.length)
  setTimeout(()=>document.getElementById('load').classList.add('hide'),300);};im.src=s;});
setTimeout(()=>document.getElementById('load').classList.add('hide'),4000); // failsafe
resize();requestAnimationFrame(frame);
</script>
</body>
</html>
